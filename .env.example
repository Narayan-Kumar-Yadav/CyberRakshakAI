BOT_TOKEN=your_telegram_bot_token_here
BOT_NAME=Cyber_RakshakBot
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json

DATABASE_PATH=./data/cyberrakshak.sqlite3
REDIS_URL=redis://localhost:6379/0

HIBP_API_KEY=your_haveibeenpwned_api_key_here
HIBP_USER_AGENT=CyberRakshak.ai Security Bot

VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
URLSCAN_API_KEY=your_urlscan_api_key_here
ENABLED_PROVIDERS=virustotal,urlhaus,abuseipdb,urlscan
PROVIDER_TIMEOUT_SECONDS=8
URLSCAN_VISIBILITY=unlisted
URLSCAN_POLL_ATTEMPTS=2
URLSCAN_POLL_DELAY_SECONDS=2
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

ADMIN_IDS=123456789,987654321
DEFAULT_RATE_LIMIT=12
DEFAULT_RATE_WINDOW_SECONDS=60
TEXT_MAX_LENGTH=4000
ENABLE_REDIS_METRICS=true
METRICS_TTL_SECONDS=86400
